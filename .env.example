DATABRICKS_HOST=https://e2-demo-field-eng.cloud.databricks.com
DATABRICKS_TOKEN=REPLACE_WITH_PAT

# Routing context
DATABRICKS_CATALOG=bx3
DATABRICKS_SCHEMA=otel_demo
OTEL_SERVICE_NAME=otel-local-mac-emitter

# Mandatory target tables (used in X-Databricks-UC-Table-Name header)
OTEL_SPANS_TABLE=bx3.otel_demo.otel_spans_v2
OTEL_LOGS_TABLE=bx3.otel_demo.otel_logs_v2
OTEL_METRICS_TABLE=bx3.otel_demo.otel_metrics

# Optional: set to enable SQL verification queries from local notebook
DATABRICKS_WAREHOUSE_ID=

# Optional: Genie space used by Ask Genie tab
GENIE_SPACE_ID=
